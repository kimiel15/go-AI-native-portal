generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id           String  @id
  teamName     String
  department   String
  members      Json
  registeredAt String
  submissionId String?
}

model Submission {
  id              String @id
  teamId          String @unique
  teamName        String
  gitRepoUrl      String
  measuredResults String
  status          String @default("draft")  // "draft" | "submitted"
  submittedAt     String
}

model Participant {
  id       String  @id
  name     String
  email    String  @unique
  teamId   String?
  teamName String?
}

model Assessment {
  id                     String  @id
  teamId                 String
  participantName        String
  participantEmail       String  @unique
  q1                     String
  q2                     String
  q3                     String
  q5                     String
  q4_essay               String
  q6_essay               String
  q7_essay               String
  mcScore                Int
  mcMax                  Int
  essayScores            Json?
  essayTotal             Int?
  essayMax               Int
  totalScore             Int?
  totalMax               Int
  totalPercent           Float?
  preliminaryLevel       String?
  categoryRecommendation String?
  validation             Json?
  submittedAt            String
}
