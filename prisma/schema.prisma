generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id           String  @id
  teamName     String
  department   String
  members      Json
  registeredAt String
  submissionId String?
}

model Submission {
  id              String  @id
  teamId          String  @unique
  teamName        String
  gitRepoUrl      String
  measuredResults String
  businessValue   String? // "revenue-growth" | "ai-containment"
  status          String  @default("draft")  // "draft" | "submitted"
  submittedAt     String
}

model Participant {
  id       String  @id
  name     String
  email    String  @unique
  siebelId String?
  teamId   String?
  teamName String?
}

model AIUsage {
  id         String @id
  siebelId   String @unique
  tokens     Float  // total tokens across the snapshot window
  costUsd    Float? // optional dollar figure from the same export
  uploadedAt String
}

model JudgeScore {
  id                    String  @id
  submissionId          String
  judgeId               String  // Siebel ID of the judge
  businessValue         Int
  solutionEffectiveness Int
  productionEvidence    Int
  problemClarity        Int
  aiIntegration         Int
  totalScore            Float
  notes                 String?
  scoredAt              String

  @@unique([submissionId, judgeId])
}

model Setting {
  key   String @id
  value String
}

model Announcement {
  id        String  @id
  type      String  // 'tip' | 'reminder' | 'update'
  tag       String
  title     String
  body      String
  date      String
  link      String?
  linkLabel String?
  imageUrl  String? // hosted image; when set, card renders full-bleed image
  external  Boolean @default(false)
  active    Boolean @default(true)
  order     Int     @default(0)
  createdAt String
}

model Assessment {
  id                     String  @id
  teamId                 String?
  participantName        String
  participantEmail       String  @unique
  q1                     String
  q2                     String
  q3                     String
  q5                     String
  q4_essay               String
  q6_essay               String
  q7_essay               String
  mcScore                Int
  mcMax                  Int
  essayScores            Json?
  essayTotal             Int?
  essayMax               Int
  totalScore             Int?
  totalMax               Int
  totalPercent           Float?
  preliminaryLevel       String?
  categoryRecommendation String?
  validation             Json?
  submittedAt            String
}
