generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id           String  @id
  teamName     String
  department   String
  members      Json
  registeredAt String
  submissionId String?
}

model Submission {
  id              String @id
  teamId          String @unique
  teamName        String
  gitRepoUrl      String
  measuredResults String
  status          String @default("draft")  // "draft" | "submitted"
  submittedAt     String
}

model Participant {
  id       String  @id
  name     String
  email    String  @unique
  siebelId String?
  teamId   String?
  teamName String?
}

model AIUsage {
  id         String @id
  siebelId   String
  month      String   // "YYYY-MM" (e.g., "2026-03")
  amountUsd  Float
  uploadedAt String

  @@unique([siebelId, month])
  @@index([siebelId])
}

model Assessment {
  id                     String  @id
  teamId                 String?
  participantName        String
  participantEmail       String  @unique
  q1                     String
  q2                     String
  q3                     String
  q5                     String
  q4_essay               String
  q6_essay               String
  q7_essay               String
  mcScore                Int
  mcMax                  Int
  essayScores            Json?
  essayTotal             Int?
  essayMax               Int
  totalScore             Int?
  totalMax               Int
  totalPercent           Float?
  preliminaryLevel       String?
  categoryRecommendation String?
  validation             Json?
  submittedAt            String
}
